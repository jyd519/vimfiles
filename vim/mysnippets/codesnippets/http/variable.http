### normal-prompt

# @kulala-prompt "What is your name?" MY_VAR_NAME

POST https://echo.kulala.app/post HTTP/1.1
Content-Type: application/json

{
  "name": "{{ MY_VAR_NAME }}"
}

### password-prompt

# @kulala-prompt "What is your password?" MY_VAR_PASSWORD { type: "password" }

POST https://echo.kulala.app/post HTTP/1.1
Content-Type: application/json

{
  "password": "{{ MY_VAR_PASSWORD }}"
}

### Iterate over arrays

< {%
  request.variables.set("users", [
    { name: "Alice" },
    { name: "Bob" },
  ])
%}

GET https://echo.kulala.app/get?user={{users[*].name}} HTTP/1.1
Content-Type: application/json
### FOO2
# 使用共享变量
GET https://echo.kulala.app/get?user={{users[*].name}} HTTP/1.1

