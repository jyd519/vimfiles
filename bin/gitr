#!/bin/bash
# 时间范围示例: "1 week", "2 weeks", "10 days" 等，默认为 "1 week"

# 获取时间范围参数，默认 1 week
since_value="${1:-1 week}"

# 生成临时文件
tmpfile=$(mktemp)

# 定义输出到临时文件的函数
output_to_file() {
    echo "$1" >> "$tmpfile"
}

# 遍历所有分支（本地 + 远程 origin）
for branch in $(git for-each-ref --format='%(refname:short)' refs/heads/ refs/remotes/origin/); do
    # 检查分支在指定时间内是否有提交
    if git log --since="$since_value" --oneline "$branch" -- | grep -q .; then
        output_to_file "===== Branch: $branch ====="
        # 将提交日志格式化输出到临时文件
        git log --since="$since_value" --pretty=format:"  %h | %an | %ad | %s" --date=iso "$branch" -- >> "$tmpfile"
        output_to_file ""
        output_to_file ""
    fi
done

# 最后用 vim 打开临时文件
nvim "$tmpfile" -c "set ft=log"

# 可选：退出 vim 后删除临时文件（如需要可取消下一行注释）
rm -f "$tmpfile"
